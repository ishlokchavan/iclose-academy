# Supabase — iclose-academy-db (ref: nnkicmfsdbfpucfcnutn)
# These are safe to commit values; the publishable key is meant to ship to the client.
NEXT_PUBLIC_SUPABASE_URL=https://nnkicmfsdbfpucfcnutn.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_9l-Q557BhSo-ncBQzxQs4Q_QGyXOU3n

# Server-only. Get from: Supabase dashboard → Project Settings → API → service_role key.
# NEVER expose this to the client. Used by /src/lib/supabase/admin.ts only.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for auth redirects, email links, OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Resend SDK for non-auth transactional emails (Phase 4+).
# Supabase Auth OTP delivery already routes through Resend via SMTP settings in the
# Supabase dashboard — this is only needed if/when we send emails outside of auth.
RESEND_API_KEY=
