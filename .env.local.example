# Public site URL (used for auth redirects, email links, OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gmail SMTP — used for OTP sign-in codes and password reset emails.
# Create an app password at: myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=

# Web Push / VAPID — for browser push notifications.
